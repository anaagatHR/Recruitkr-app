# Copy to .env for local development. Expo only exposes vars prefixed EXPO_PUBLIC_.
# Anything set here overrides the defaults baked into app.json -> expo.extra.

# Main backend (recruitkr-api). Jobs, auth, applications, messages.
# Real phone against a LOCAL backend: use your PC's LAN IP, not localhost.
# EXPO_PUBLIC_API_URL=http://192.168.1.5:5000/api

# Admin panel (Recruitkr-Business) public API. Applications are mirrored here.
# Leave unset to use the app.json default; set to "" to disable mirroring entirely.
# EXPO_PUBLIC_BUSINESS_API_URL=http://localhost:8000/api/public
