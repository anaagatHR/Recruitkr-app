{
  "expo": {
    "name": "RecruitKR",
    "slug": "recruitkr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.recruitkr.app",
      "permissions": ["POST_NOTIFICATIONS"],
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "favicon": "./src/assets/icon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/icon.png",
          "color": "#274B7F"
        }
      ]
    ],
    "extra": {
      "//": "Deployed backend URL (Render). Used by the built APK.",
      "apiUrl": "https://recruitkr-api.onrender.com/api",
      "cloudinary": {
        "//": "Fill these to enable profile photo upload. cloudName + an UNSIGNED upload preset from cloudinary.com. Not secrets.",
        "cloudName": "",
        "uploadPreset": ""
      },
      "eas": {
        "projectId": "e7cdd70e-df9d-434b-88df-26ff2d456404"
      }
    }
  }
}
