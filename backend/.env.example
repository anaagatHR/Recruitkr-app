# Copy this file to ".env" and fill in your real values.

# Server port
PORT=5000

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/recruitkr
# Atlas (free cloud): mongodb+srv://<user>:<password>@<cluster>.mongodb.net/recruitkr
MONGO_URI=mongodb://127.0.0.1:27017/recruitkr

# Secret used to sign login tokens. Use a long random string in production.
JWT_SECRET=change_this_to_a_long_random_secret_string

# How long a login stays valid
JWT_EXPIRES_IN=30d

# Anthropic (Claude) API key — powers the AI features (job matching, resume
# parsing, job-description generation, applicant ranking). Get one at
# https://console.anthropic.com/. Leave blank to run without AI.
ANTHROPIC_API_KEY=
# Optional model override (defaults to a fast, low-cost model).
AI_MODEL=claude-haiku-4-5-20251001
